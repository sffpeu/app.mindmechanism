# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-auth-domain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-storage-bucket
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret

# Email Configuration
EMAIL_SERVER_HOST=your-smtp-host
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your-smtp-user
EMAIL_SERVER_PASSWORD=your-smtp-password
EMAIL_FROM=noreply@yourdomain.com

# Other Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Weather API Configuration
NEXT_PUBLIC_WEATHER_API_KEY=your-weather-api-key

# Optional: Development Configuration
# NEXT_PUBLIC_DEVELOPMENT_MODE=true

# Dev-only Google bypass (npm run dev): mints a Firebase custom token via Admin SDK.
# In Firebase Console → Project settings → Service accounts → Generate new private key,
# then paste the entire JSON as one line:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}
#
# Optional: override the fixed dev user UID (default: dev_admin_local)
# FIREBASE_DEV_ADMIN_UID=dev_admin_local
#
# Optional: sign in on /home with a typed email (dev only). Comma-separated, case-insensitive.
# DEV_AUTH_ALLOWLIST_EMAILS=you@test.com,other@example.com
# Optional: also set custom claim admin:true for allowlisted email sign-ins
# DEV_AUTH_ALLOWLIST_GRANT_ADMIN=true
#
# Local form login on /home (dev only): type "admin" in the email field and password below.
# Creates/uses a Firebase user at DEV_LOCAL_EMAIL (password is NOT stored in Firebase; only this gate).
# DEV_LOCAL_USERNAME=admin
# DEV_LOCAL_PASSWORD=123
# DEV_LOCAL_EMAIL=admin@mindmechanism.local

# ── Streaming music (Sound → Your music) ───────────────────────────────────
# Spotify Web Playback SDK + PKCE (Premium required for in-browser playback).
# Create an app at https://developer.spotify.com/dashboard — add redirect URI:
#   http://localhost:3000/auth/spotify/callback
#   https://<your-production-domain>/auth/spotify/callback
# NEXT_PUBLIC_SPOTIFY_CLIENT_ID=
#
# Apple MusicKit (developer token for MusicKit JS). In Apple Developer:
#   Certificates, Identifiers & Profiles → Keys → MusicKit key (.p8)
# Register your web origin under the MusicKit identifier if playback is blocked.
# APPLE_MUSIC_TEAM_ID=
# APPLE_MUSIC_KEY_ID=
# APPLE_MUSIC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"